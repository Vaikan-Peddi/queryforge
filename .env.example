POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=queryforge
POSTGRES_PASSWORD=queryforge
POSTGRES_DB=queryforge

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

BACKEND_PORT=8080
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
AI_SERVICE_URL=http://ai-service:8000
AI_REQUEST_TIMEOUT_SECONDS=130

# Local Ollama
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5-coder:7b
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.1
ENABLE_MOCK_LLM=false

# OpenAI-compatible API
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your-api-key

# Groq/OpenRouter/Together/LM Studio/LocalAI-compatible style
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://provider-base-url/v1
# LLM_MODEL=provider-model-name
# LLM_API_KEY=your-api-key

STORAGE_DIR=/app/storage
MAX_UPLOAD_MB=50

VITE_API_URL=http://localhost:8080
